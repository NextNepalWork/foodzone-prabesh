// Hourly/weekday order heatmap — day-of-week × hour counts.
router.get('/heatmap', authenticateToken, async (req, res) => {
  try {
    const { range = '30d' } = req.query;
    const { startDate, endDate } = parseDateRange(range);
    const result = await query(`
      SELECT EXTRACT(DOW FROM created_at)::int  AS dow,
             EXTRACT(HOUR FROM created_at)::int AS hour,
             COUNT(*)::int                      AS orders,
             COALESCE(SUM(total), 0)::numeric   AS revenue
      FROM orders
      WHERE created_at::date BETWEEN $1 AND $2
      GROUP BY dow, hour
      ORDER BY dow, hour
    `, [startDate, endDate]);
    res.json(result.rows);
  } catch (error) {
    console.error('Error fetching heatmap:', error);
    res.status(500).json({ error: 'Failed to fetch heatmap' });
  }
});

// Slow-moving menu items: least-ordered items in range.
router.get('/slow-movers', authenticateToken, async (req, res) => {
  try {
    const { range = '30d', limit = 20 } = req.query;
    const { startDate, endDate } = parseDateRange(range);
    const result = await query(`
      SELECT mi.id, mi.name, mi.category,
             COALESCE(SUM(oi.quantity), 0)::int                            AS units_sold,
             COALESCE(SUM(oi.quantity * oi.price), 0)::numeric             AS revenue
      FROM menu_items mi
      LEFT JOIN order_items oi ON oi.menu_item_name = mi.name
      LEFT JOIN orders o       ON o.id = oi.order_id
                               AND o.created_at::date BETWEEN $1 AND $2
      GROUP BY mi.id, mi.name, mi.category
      ORDER BY units_sold ASC, mi.name ASC
      LIMIT $3
    `, [startDate, endDate, Number(limit)]);
    res.json(result.rows);
  } catch (error) {
    console.error('Error fetching slow-movers:', error);
    res.status(500).json({ error: 'Failed to fetch slow-movers' });
  }
});

// Profit & Loss: revenue from paid orders minus expenses from daybook.
router.get('/profit-loss', authenticateToken, async (req, res) => {
  try {
    const { range = '30d' } = req.query;
    const { startDate, endDate } = parseDateRange(range);

    const revenueR = await query(`
      SELECT COALESCE(SUM(total), 0)::numeric AS revenue
      FROM orders
      WHERE payment_status = 'paid' AND created_at::date BETWEEN $1 AND $2
    `, [startDate, endDate]);

    const expR = await query(`
      SELECT COALESCE(SUM(amount), 0)::numeric AS total
      FROM daybook_transactions
      WHERE transaction_type = 'expense' AND transaction_date BETWEEN $1 AND $2
    `, [startDate, endDate]);

    const revenue = Number(revenueR.rows[0].revenue);
    const expenses = Number(expR.rows[0].total);
    const cogs = 0; // TODO: derive from recipe_ingredients once costed
    const gross_profit = revenue - cogs;
    const net_profit = gross_profit - expenses;
    res.json({ revenue, cogs, gross_profit, expenses, net_profit });
  } catch (error) {
    console.error('Error fetching profit-loss:', error);
    res.status(500).json({ error: 'Failed to fetch profit-loss' });
  }
});

router.get('/profit-loss-trend', authenticateToken, async (req, res) => {
  try {
    const { range = '30d' } = req.query;
    const { startDate, endDate } = parseDateRange(range);
    const result = await query(`
      WITH daily_rev AS (
        SELECT DATE(created_at) AS d, COALESCE(SUM(total), 0)::numeric AS revenue
        FROM orders
        WHERE payment_status = 'paid' AND created_at::date BETWEEN $1 AND $2
        GROUP BY DATE(created_at)
      ),
      daily_exp AS (
        SELECT transaction_date AS d, COALESCE(SUM(amount), 0)::numeric AS expenses
        FROM daybook_transactions
        WHERE transaction_type = 'expense' AND transaction_date BETWEEN $1 AND $2
        GROUP BY transaction_date
      )
      SELECT COALESCE(r.d, e.d) AS bucket,
             COALESCE(r.revenue, 0) AS revenue,
             COALESCE(e.expenses, 0) AS expenses,
             COALESCE(r.revenue, 0) - COALESCE(e.expenses, 0) AS net_profit
      FROM daily_rev r
      FULL OUTER JOIN daily_exp e ON r.d = e.d
      ORDER BY bucket
    `, [startDate, endDate]);
    res.json(result.rows);
  } catch (error) {
    console.error('Error fetching profit-loss trend:', error);
    res.status(500).json({ error: 'Failed to fetch profit-loss trend' });
  }
});

// Get expenses from daybook_transactions
router.get('/expenses', authenticateToken, async (req, res) => {
  try {
    const { range = '30d' } = req.query;
    const { startDate, endDate } = parseDateRange(range);
    const result = await query(`
      SELECT 
        id, 
        transaction_date as expense_date, 
        category, 
        description, 
        amount, 
        payment_method, 
        reference as reference_number,
        created_by,
        created_at
      FROM daybook_transactions
      WHERE transaction_type = 'expense'
        AND transaction_date BETWEEN $1 AND $2
      ORDER BY transaction_date DESC, id DESC
    `, [startDate, endDate]);
    res.json(result.rows);
  } catch (error) {
    console.error('Error fetching expenses:', error);
    res.json([]);
  }
});

// Add new expense to daybook
router.post('/expenses', authenticateToken, async (req, res) => {
  try {
    const {
      expense_date, category, description, amount,
      payment_method, reference_number, notes
    } = req.body;

    if (!category || !amount) {
      return res.status(400).json({ error: 'category and amount are required' });
    }

    const txDate = expense_date || new Date().toISOString().split('T')[0];
    const fullDescription = notes ? `${description || ''} - ${notes}` : description;

    const result = await query(`
      INSERT INTO daybook_transactions
        (transaction_date, transaction_type, category, amount, description, payment_method, reference, created_by, created_at)
      VALUES ($1, 'expense', $2, $3, $4, $5, $6, $7, NOW())
      RETURNING *
    `, [
      txDate,
      category,
      Number(amount),
      fullDescription || null,
      payment_method || null,
      reference_number || null,
      req.user?.username || null
    ]);

    res.json(result.rows[0]);
  } catch (error) {
    console.error('Error creating expense:', error);
    res.status(500).json({ error: 'Failed to create expense', details: error.message });
  }
});

// Update expense in daybook
router.put('/expenses/:id', authenticateToken, async (req, res) => {
  try {
    const { id } = req.params;
    const {
      expense_date, category, description, amount,
      payment_method, reference_number, notes
    } = req.body;

    const fullDescription = notes ? `${description || ''} - ${notes}` : description;

    const result = await query(`
      UPDATE daybook_transactions
      SET 
        transaction_date = COALESCE($1, transaction_date),
        category = COALESCE($2, category),
        amount = COALESCE($3, amount),
        description = COALESCE($4, description),
        payment_method = COALESCE($5, payment_method),
        reference = COALESCE($6, reference),
        updated_at = NOW()
      WHERE id = $7 AND transaction_type = 'expense'
      RETURNING *
    `, [
      expense_date || null,
      category || null,
      amount ? Number(amount) : null,
      fullDescription || null,
      payment_method || null,
      reference_number || null,
      id
    ]);

    if (result.rows.length === 0) {
      return res.status(404).json({ error: 'Expense not found' });
    }

    res.json(result.rows[0]);
  } catch (error) {
    console.error('Error updating expense:', error);
    res.status(500).json({ error: 'Failed to update expense', details: error.message });
  }
});

// Delete expense from daybook
router.delete('/expenses/:id', authenticateToken, async (req, res) => {
  try {
    const { id } = req.params;

    const result = await query(`
      DELETE FROM daybook_transactions
      WHERE id = $1 AND transaction_type = 'expense'
      RETURNING id
    `, [id]);

    if (result.rows.length === 0) {
      return res.status(404).json({ error: 'Expense not found' });
    }

    res.json({ success: true, id: result.rows[0].id });
  } catch (error) {
    console.error('Error deleting expense:', error);
    res.status(500).json({ error: 'Failed to delete expense', details: error.message });
  }
});

// Get expense categories with totals from daybook
router.get('/expense-categories', authenticateToken, async (req, res) => {
  try {
    const { range = '30d' } = req.query;
    const { startDate, endDate } = parseDateRange(range);
    const result = await query(`
      SELECT 
        category, 
        COUNT(*)::int AS count, 
