// Category breakdown
router.get('/category-breakdown', authenticateToken, async (req, res) => {
  try {
    const { range = '30d' } = req.query;
    const { startDate, endDate } = parseDateRange(range);
    
    const result = await query(`
      SELECT 
        m.category,
        COUNT(oi.id) as items_sold,
        COALESCE(SUM(oi.quantity * oi.price), 0) as revenue
      FROM order_items oi
      JOIN orders o ON oi.order_id = o.id
      JOIN menu_items m ON oi.menu_item_id = m.id
      WHERE o.payment_status = 'paid'
        AND o.created_at::date BETWEEN $1 AND $2
      GROUP BY m.category
      ORDER BY revenue DESC
    `, [startDate, endDate]);
    
    res.json({
      categories: result.rows.map(r => ({
        category: r.category || 'Uncategorized',
        items_sold: r.items_sold,
        revenue: r.revenue
      }))
    });
  } catch (error) {
    console.error('Error fetching category breakdown:', error);
    res.status(500).json({ error: 'Failed to fetch category breakdown' });
  }
});

// Top items
router.get('/top-items', authenticateToken, async (req, res) => {
  try {
    const { range = '30d', metric = 'revenue', limit = 30 } = req.query;
    const { startDate, endDate } = parseDateRange(range);
    
    const orderBy = metric === 'quantity' ? 'total_quantity' : 'revenue';
    
    const result = await query(`
      SELECT 
        m.name,
        m.category,
        SUM(oi.quantity) as total_quantity,
        COALESCE(SUM(oi.quantity * oi.price), 0) as revenue
      FROM order_items oi
      JOIN orders o ON oi.order_id = o.id
      JOIN menu_items m ON oi.menu_item_id = m.id
      WHERE o.payment_status = 'paid'
        AND o.created_at::date BETWEEN $1 AND $2
      GROUP BY m.id, m.name, m.category
      ORDER BY ${orderBy} DESC
      LIMIT $3
    `, [startDate, endDate, parseInt(limit)]);
    
    res.json({
      items: result.rows.map(r => ({
        name: r.name,
        category: r.category,
        quantity: r.total_quantity,
        revenue: r.revenue
      }))
    });
  } catch (error) {
    console.error('Error fetching top items:', error);
    res.status(500).json({ error: 'Failed to fetch top items' });
  }
});

// Hourly load
router.get('/hourly-load', authenticateToken, async (req, res) => {
  try {
    const { range = '30d' } = req.query;
    const { startDate, endDate } = parseDateRange(range);
    
    const result = await query(`
      SELECT 
        EXTRACT(HOUR FROM created_at) as hour,
        COUNT(*) as orders,
        COALESCE(SUM(total), 0) as revenue
      FROM orders
      WHERE payment_status = 'paid'
        AND created_at::date BETWEEN $1 AND $2
      GROUP BY EXTRACT(HOUR FROM created_at)
      ORDER BY hour
    `, [startDate, endDate]);
    
    res.json(result.rows);
  } catch (error) {
    console.error('Error fetching hourly load:', error);
    res.status(500).json({ error: 'Failed to fetch hourly load' });
  }
});

// Customers report
router.get('/customers', authenticateToken, async (req, res) => {
  try {
    const { range = '30d', limit = 25 } = req.query;
    const { startDate, endDate } = parseDateRange(range);
    
    const result = await query(`
      SELECT 
        COALESCE(c.name, 'Guest') as name,
        c.phone,
        COUNT(o.id) as order_count,
        COALESCE(SUM(o.total), 0) as total_spent,
        MAX(o.created_at) as last_order
      FROM orders o
      LEFT JOIN customers c ON o.customer_id = c.id
      WHERE o.payment_status = 'paid'
        AND o.created_at::date BETWEEN $1 AND $2
      GROUP BY COALESCE(c.name, 'Guest'), c.phone
      ORDER BY total_spent DESC
      LIMIT $3
    `, [startDate, endDate, parseInt(limit)]);
    
    res.json({
      top: result.rows.map(r => ({
        name: r.name,
        phone: r.phone || 'N/A',
        order_count: r.order_count,
        total_spent: r.total_spent,
        last_order: r.last_order
      }))
    });
  } catch (error) {
    console.error('Error fetching customers:', error);
    res.status(500).json({ error: 'Failed to fetch customers' });
  }
});

