const express = require('express');
const router = express.Router();
const { query } = require('../database/config');
const { authenticateToken } = require('../middleware/auth');

// Helper to parse date range
const parseDateRange = (range, from, to) => {
  // If custom from/to dates are provided, use them
  if (from && to) {
    return { startDate: from, endDate: to };
  }
  
  const today = new Date();
  today.setHours(0, 0, 0, 0); // Start of today
  let startDate, endDate = today;
  
  switch(range) {
    case 'today':
      startDate = today;
      break;
    case 'yesterday':
      startDate = new Date(today.getTime() - 1 * 24 * 60 * 60 * 1000);
      endDate = new Date(today.getTime() - 1 * 24 * 60 * 60 * 1000);
      break;
    case '7d':
      startDate = new Date(today.getTime() - 7 * 24 * 60 * 60 * 1000);
      break;
    case '30d':
      startDate = new Date(today.getTime() - 30 * 24 * 60 * 60 * 1000);
      break;
    case '90d':
      startDate = new Date(today.getTime() - 90 * 24 * 60 * 60 * 1000);
      break;
    case 'month':
      // This month - from 1st to today
      startDate = new Date(today.getFullYear(), today.getMonth(), 1);
      break;
    case 'lastmonth':
      // Last month - from 1st to last day of previous month
      startDate = new Date(today.getFullYear(), today.getMonth() - 1, 1);
      endDate = new Date(today.getFullYear(), today.getMonth(), 0);
      break;
    case 'year':
      // Year to date - from Jan 1 to today
      startDate = new Date(today.getFullYear(), 0, 1);
      break;
    case 'all':
      // All time - from 2020-01-01 to today
      startDate = new Date(2020, 0, 1);
      break;
    default:
      // Default to last 30 days
      startDate = new Date(today.getTime() - 30 * 24 * 60 * 60 * 1000);
  }
  
  return {
    startDate: startDate.toISOString().split('T')[0],
    endDate: endDate.toISOString().split('T')[0]
  };
};

// Overview stats
router.get('/overview', authenticateToken, async (req, res) => {
  try {
    const { range = '30d', from, to } = req.query;
    const { startDate, endDate } = parseDateRange(range, from, to);
    
    const result = await query(`
      SELECT 
        COUNT(*) as total_orders,
        COALESCE(SUM(total), 0) as total_revenue,
        COALESCE(AVG(total), 0) as avg_order_value,
        COUNT(DISTINCT customer_id) as unique_customers,
        COALESCE(SUM(CASE WHEN order_type = 'dine-in' THEN total ELSE 0 END), 0) as dine_in_revenue,
        COALESCE(SUM(CASE WHEN order_type = 'delivery' THEN total ELSE 0 END), 0) as delivery_revenue
      FROM orders
      WHERE payment_status = 'paid'
        AND created_at::date BETWEEN $1 AND $2
    `, [startDate, endDate]);
    
    const data = result.rows[0];
    res.json({
      kpis: {
        totalRevenue: { value: data.total_revenue, change: 0 },
        totalOrders: { value: data.total_orders, change: 0 },
        avgOrderValue: { value: data.avg_order_value, change: 0 },
        uniqueCustomers: { value: data.unique_customers, change: 0 },
        dineInRevenue: { value: data.dine_in_revenue, change: 0 },
        deliveryRevenue: { value: data.delivery_revenue, change: 0 },
        totalDiscount: { value: 0, change: 0 },
        completionRate: 100
      }
    });
  } catch (error) {
    console.error('Error fetching overview:', error);
    res.status(500).json({ error: 'Failed to fetch overview' });
  }
});

// Sales trend
router.get('/sales-trend', authenticateToken, async (req, res) => {
  try {
    const { range = '30d', granularity = 'day' } = req.query;
    const { startDate, endDate } = parseDateRange(range);
    
    const result = await query(`
      SELECT 
        DATE(created_at) as bucket,
        COUNT(*) as orders,
        COALESCE(SUM(total), 0) as revenue
      FROM orders
      WHERE payment_status = 'paid'
        AND created_at::date BETWEEN $1 AND $2
      GROUP BY DATE(created_at)
      ORDER BY bucket
    `, [startDate, endDate]);
    
    res.json({
      points: result.rows.map(r => ({
        bucket: r.bucket,
        orders: r.orders,
        revenue: r.revenue
      }))
    });
  } catch (error) {
    console.error('Error fetching sales trend:', error);
    res.status(500).json({ error: 'Failed to fetch sales trend' });
  }
});

// Payment mix
router.get('/payment-mix', authenticateToken, async (req, res) => {
  try {
    const { range = '30d' } = req.query;
    const { startDate, endDate } = parseDateRange(range);
    
    const result = await query(`
      SELECT 
        payment_method as method,
        COUNT(*) as count,
        COALESCE(SUM(total), 0) as amount
      FROM orders
      WHERE payment_status = 'paid'
        AND created_at::date BETWEEN $1 AND $2
      GROUP BY payment_method
      ORDER BY amount DESC
    `, [startDate, endDate]);
    
    res.json({
      methods: result.rows.map(r => ({
        method: r.method || 'Unknown',
        count: r.count,
        amount: r.amount
      }))
    });
  } catch (error) {
    console.error('Error fetching payment mix:', error);
    res.status(500).json({ error: 'Failed to fetch payment mix' });
  }
});

