      GROUP BY category
      ORDER BY total DESC
    `, [startDate, endDate]);
    res.json(result.rows);
  } catch (error) {
    console.error('Error fetching expense categories:', error);
    res.json([]);
  }
});

router.get('/staff-activity', authenticateToken, async (req, res) => {
  try {
    const { range = '30d' } = req.query;
    const { startDate, endDate } = parseDateRange(range);
    // Daybook transactions carry created_by for many action endpoints.
    const result = await query(`
      SELECT COALESCE(created_by, 'system') AS staff,
             COUNT(*)::int                   AS actions,
             COALESCE(SUM(amount), 0)::numeric AS total_amount
      FROM daybook_transactions
      WHERE transaction_date BETWEEN $1 AND $2
      GROUP BY COALESCE(created_by, 'system')
      ORDER BY actions DESC
    `, [startDate, endDate]);
    res.json(result.rows);
  } catch (error) {
    console.error('Error fetching staff activity:', error);
    res.json([]);
  }
});

router.get('/discounts', authenticateToken, async (req, res) => {
  try {
    const { range = '30d' } = req.query;
    const { startDate, endDate } = parseDateRange(range);
    const result = await query(`
      SELECT DATE(created_at) AS bucket,
             COUNT(*) FILTER (WHERE COALESCE(discount, 0) > 0)::int AS orders_with_discount,
             COALESCE(SUM(discount), 0)::numeric                    AS total_discount
      FROM orders
      WHERE created_at::date BETWEEN $1 AND $2
      GROUP BY DATE(created_at)
      ORDER BY bucket
    `, [startDate, endDate]);
    res.json(result.rows);
  } catch (error) {
    console.error('Error fetching discounts:', error);
    res.json([]);
  }
});

router.get('/table-performance', authenticateToken, async (req, res) => {
  try {
    const { range = '30d' } = req.query;
    const { startDate, endDate } = parseDateRange(range);
    const result = await query(`
      SELECT table_id,
             COUNT(*)::int                     AS orders,
             COALESCE(SUM(total), 0)::numeric  AS revenue,
             COALESCE(AVG(total), 0)::numeric  AS avg_ticket
      FROM orders
      WHERE order_type = 'dine-in'
        AND table_id IS NOT NULL
        AND created_at::date BETWEEN $1 AND $2
      GROUP BY table_id
      ORDER BY revenue DESC
    `, [startDate, endDate]);
    res.json(result.rows);
  } catch (error) {
    console.error('Error fetching table performance:', error);
    res.json([]);
  }
});

router.get('/inventory-valuation', authenticateToken, async (req, res) => {
  try {
    const result = await query(`
      SELECT id, name, unit,
             COALESCE(current_stock, 0)::numeric AS stock,
             COALESCE(cost_per_unit, 0)::numeric AS unit_cost,
             (COALESCE(current_stock, 0) * COALESCE(cost_per_unit, 0))::numeric AS value
      FROM ingredients
      WHERE is_active IS NOT FALSE
      ORDER BY value DESC
    `);
    const total_value = result.rows.reduce((s, r) => s + Number(r.value || 0), 0);
    res.json({ enabled: true, total_value, items: result.rows });
  } catch (error) {
    console.error('Error fetching inventory valuation:', error);
    res.json({ enabled: false, total_value: 0, items: [] });
  }
});

// Export data as CSV
router.get('/export', authenticateToken, async (req, res) => {
  try {
    const { range = '30d', type = 'orders' } = req.query;
    const { startDate, endDate } = parseDateRange(range);
    
    let data, filename, headers;
    
    switch (type) {
      case 'orders':
        const orders = await query(`
          SELECT 
            o.id, o.order_number, o.order_type, o.table_id,
            o.total, o.payment_method, o.payment_status,
            o.created_at, COALESCE(c.name, 'Guest') as customer_name
          FROM orders o
          LEFT JOIN customers c ON o.customer_id = c.id
          WHERE o.created_at::date BETWEEN $1 AND $2
          ORDER BY o.created_at DESC
        `, [startDate, endDate]);
        data = orders.rows;
        filename = `orders_${startDate}_${endDate}.csv`;
        headers = ['ID', 'Order Number', 'Type', 'Table', 'Total', 'Payment Method', 'Status', 'Date', 'Customer'];
        break;
        
      case 'expenses':
        const expenses = await query(`
          SELECT 
            id, transaction_date as expense_date, category, 
            description, amount, payment_method, reference, created_by
          FROM daybook_transactions
          WHERE transaction_type = 'expense'
            AND transaction_date BETWEEN $1 AND $2
          ORDER BY transaction_date DESC
        `, [startDate, endDate]);
        data = expenses.rows;
        filename = `expenses_${startDate}_${endDate}.csv`;
        headers = ['ID', 'Date', 'Category', 'Description', 'Amount', 'Payment Method', 'Reference', 'Created By'];
        break;
        
      case 'sales':
        const sales = await query(`
          SELECT 
            DATE(created_at) as date,
            COUNT(*) as orders,
            COALESCE(SUM(total), 0) as revenue,
            COALESCE(AVG(total), 0) as avg_order_value
          FROM orders
          WHERE payment_status = 'paid'
            AND created_at::date BETWEEN $1 AND $2
          GROUP BY DATE(created_at)
          ORDER BY date
        `, [startDate, endDate]);
        data = sales.rows;
        filename = `sales_${startDate}_${endDate}.csv`;
        headers = ['Date', 'Orders', 'Revenue', 'Avg Order Value'];
        break;
        
      default:
        return res.status(400).json({ error: 'Invalid export type' });
    }
    
    // Generate CSV
    const csvRows = [headers.join(',')];
    data.forEach(row => {
      const values = Object.values(row).map(val => {
        if (val === null || val === undefined) return '';
        const str = String(val);
        return str.includes(',') || str.includes('"') ? `"${str.replace(/"/g, '""')}"` : str;
      });
      csvRows.push(values.join(','));
    });
    
    const csv = csvRows.join('\n');
    
    res.setHeader('Content-Type', 'text/csv');
    res.setHeader('Content-Disposition', `attachment; filename="${filename}"`);
    res.send(csv);
    
  } catch (error) {
    console.error('Error exporting data:', error);
    res.status(500).json({ error: 'Failed to export data' });
  }
});

module.exports = router;
