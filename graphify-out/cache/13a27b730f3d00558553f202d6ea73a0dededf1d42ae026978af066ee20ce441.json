assName=\"text-gray-600\">{selectedCustomer.phone}</p>\n                      {selectedCustomer.email && (\n                        <p className=\"text-gray-500\">{selectedCustomer.email}</p>\n                      )}\n                    </div>\n                  </div>\n\n                  {/* Customer Stats */}\n                  <div className=\"grid grid-cols-3 gap-4\">\n                    <div className=\"text-center p-4 bg-blue-50 rounded-lg\">\n                      <p className=\"text-2xl font-bold text-blue-600\">{stats.totalOrders}</p>\n                      <p className=\"text-sm text-gray-600\">Total Orders</p>\n                    </div>\n                    <div className=\"text-center p-4 bg-green-50 rounded-lg\">\n                      <p className=\"text-2xl font-bold text-green-600\">NPR {stats.totalSpent}</p>\n                      <p className=\"text-sm text-gray-600\">Total Spent</p>\n                    </div>\n                    <div className=\"text-center p-4 bg-purple-50 rounded-lg\">\n                      <p className=\"text-2xl font-bold text-purple-600\">\n                        NPR {stats.totalOrders > 0 ? Math.round(stats.totalSpent / stats.totalOrders) : 0}\n                      </p>\n                      <p className=\"text-sm text-gray-600\">Avg Order</p>\n                    </div>\n                  </div>\n\n                  {/* Order History */}\n                  <div>\n                    <h5 className=\"text-lg font-semibold mb-4\">Order History</h5>\n                    {stats.orders.length === 0 ? (\n                      <p className=\"text-gray-500 text-center py-8\">No orders found</p>\n                    ) : (\n                      <div className=\"space-y-3 max-h-60 overflow-y-auto\">\n                        {stats.orders\n                          .sort((a, b) => new Date(b.created_at) - new Date(a.created_at))\n                          .map((order) => (\n                            <div key={order.id} className=\"border border-gray-200 rounded-lg p-3\">\n                              <div className=\"flex items-center justify-between mb-2\">\n                                <span className=\"font-medium\">\n                                  {order.order_type === 'dine-in' ? `Table ${order.table_id}` : 'Delivery'}\n                                </span>\n                                <p className=\"text-sm text-gray-600\">\n                                  {order.customer_name} \u2022 {new Date(order.created_at).toLocaleString()}\n                                </p>\n                                {order.order_type === 'delivery' && order.latitude && order.longitude && (\n                                  <p className=\"text-xs text-gray-500 mt-1\">\n                                    \ud83d\udccd {order.latitude}, {order.longitude}\n                                  </p>\n                                )}\n                              </div>\n                              <div className=\"flex items-center justify-between\">\n                                <span className=\"text-sm text-gray-600\">\n                                  {order.items?.length || 0} items\n                                </span>\n                                <div className=\"flex items-center space-x-2\">\n                                  <span className=\"font-semibold\">NPR {order.total_amount}</span>\n                                  <span className={`px-2 py-1 text-xs rounded-full ${\n                                    order.status === 'completed' ? 'bg-green-100 text-green-700' :\n                                    order.status === 'pending' ? 'bg-yellow-100 text-yellow-700' :\n                                    'bg-blue-100 text-blue-700'\n                                  }`}>\n                                    {order.status}\n                                  </span>\n                                </div>\n                              </div>\n                            </div>\n                          ))\n                        }\n                      </div>\n                    )}\n                  </div>\n                </div>\n              );\n            })", "source_file": "/Users/aasmidhungana/Desktop/foodzone-main/raw/client/src/pages/AdminPremium.js", "source_location": "L1644"}, {"caller_nid": "adminpremium_analyticsviewplaceholder", "callee": "useState", "source_file": "/Users/aasmidhungana/Desktop/foodzone-main/raw/client/src/pages/AdminPremium.js", "source_location": "L1737"}, {"caller_nid": "adminpremium_analyticsviewplaceholder", "callee": "getAnalyticsData", "source_file": "/Users/aasmidhungana/Desktop/foodzone-main/raw/client/src/pages/AdminPremium.js", "source_location": "L1837"}, {"caller_nid": "adminpremium_analyticsviewplaceholder", "callee": "toLocaleString", "source_file": "/Users/aasmidhungana/Desktop/foodzone-main/raw/client/src/pages/AdminPremium.js", "source_location": "L1991"}, {"caller_nid": "adminpremium_analyticsviewplaceholder", "callee": "round", "source_file": "/Users/aasmidhungana/Desktop/foodzone-main/raw/client/src/pages/AdminPremium.js", "source_location": "L2015"}, {"caller_nid": "adminpremium_analyticsviewplaceholder", "callee": "round", "source_file": "/Users/aasmidhungana/Desktop/foodzone-main/raw/client/src/pages/AdminPremium.js", "source_location": "L2029"}, {"caller_nid": "adminpremium_analyticsviewplaceholder", "callee": "map", "source_file": "/Users/aasmidhungana/Desktop/foodzone-main/raw/client/src/pages/AdminPremium.js", "source_location": "L2046"}, {"caller_nid": "adminpremium_analyticsviewplaceholder", "callee": "map", "source_file": "/Users/aasmidhungana/Desktop/foodzone-main/raw/client/src/pages/AdminPremium.js", "source_location": "L2076"}, {"caller_nid": "adminpremium_analyticsviewplaceholder", "callee": "entries", "source_file": "/Users/aasmidhungana/Desktop/foodzone-main/raw/client/src/pages/AdminPremium.js", "source_location": "L2076"}, {"caller_nid": "admin