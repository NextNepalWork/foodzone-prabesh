# Food Zone Frontend - Production Environment Configuration Template
# Copy this to .env.production and update URLs for your production deployment

# Production Backend URLs - UPDATE THESE FOR YOUR DEPLOYMENT
REACT_APP_API_URL=https://api.foodzone.com.np
REACT_APP_BACKEND_URL=https://api.foodzone.com.np
REACT_APP_SOCKET_URL=https://api.foodzone.com.np
REACT_APP_API_PORT=443
NEXT_PUBLIC_API_URL=https://api.foodzone.com.np

# Production Environment
NODE_ENV=production

# Production Optimizations
GENERATE_SOURCEMAP=false
INLINE_RUNTIME_CHUNK=false

# Example configurations for common deployment platforms:
# 
# For Render.com:
# REACT_APP_API_URL=https://your-app-name.onrender.com
# REACT_APP_BACKEND_URL=https://your-app-name.onrender.com
# 
# For Heroku:
# REACT_APP_API_URL=https://your-app-name.herokuapp.com
# REACT_APP_BACKEND_URL=https://your-app-name.herokuapp.com
#
# For Netlify + separate backend:
# REACT_APP_API_URL=https://your-backend.herokuapp.com
# REACT_APP_BACKEND_URL=https://your-backend.herokuapp.com
#
# For custom domain:
# REACT_APP_API_URL=https://api.yourdomain.com
# REACT_APP_BACKEND_URL=https://api.yourdomain.com
